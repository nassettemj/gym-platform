generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A gym customer (tenant) on the platform.
model Gym {
  id               String            @id @default(cuid())
  name             String
  slug             String            @unique
  status           GymStatus         @default(ACTIVE)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stripeCustomerId String?
  classes          Class[]
  events           Event[]
  customizations   GymCustomization?
  instructors      Instructor[]
  locations        Location[]
  members          Member[]
  membershipPlans  MembershipPlan[]
  orders           Order[]
  products         Product[]
  users            User[]
}

/// Per-gym branding and feature configuration.
model GymCustomization {
  id             String  @id @default(cuid())
  gymId          String  @unique
  logoUrl        String?
  primaryColor   String?
  secondaryColor String?
  customCss      String?
  featureFlags   Json?
  customFields   Json?
  gym            Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

/// Application user (login). Usually linked to an adult Member.
model User {
  id                 String                  @id @default(cuid())
  gymId              String?
  email              String                  @unique
  password           String?
  name               String?
  role               UserRole                @default(MEMBER)
  memberId           String?                 @unique
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  gym                Gym?                    @relation(fields: [gymId], references: [id])
  member             Member?                 @relation("MemberUser", fields: [memberId], references: [id])
  beltStripeChanges  MemberBeltStripeLog[]   @relation("UserBeltStripeChanges")
  profileChangeLogs  MemberProfileChangeLog[] @relation("UserProfileChanges")
}

/// Physical gym location belonging to a Gym (tenant).
model Location {
  id              String           @id @default(cuid())
  gymId           String
  name            String
  address         String?
  timezone        String           @default("UTC")
  settings        Json?
  checkIns        CheckIn[]
  classes         Class[]
  events          Event[]
  gym             Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  membershipPlans MembershipPlan[]
  orders          Order[]
  products        Product[]
}

/// Individual member (adult or child) of a gym.
model Member {
  id               String              @id @default(cuid())
  gymId            String
  firstName        String
  lastName         String
  email            String?
  /// Stripe Customer ID for this member (cus_...)
  stripeCustomerId String?
  phone            String?
  birthDate        DateTime?
  belt             BeltRank?
  stripes          Int?
  emergencyContact String?
  medicalNotes     String?
  beltRank         String?
  discipline       String?
  status           MemberStatus        @default(ACTIVE)
  memberType       MemberType          @default(ADULT)
  customFields     Json?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  checkIns         CheckIn[]
  eventRegs        EventRegistration[]
  instructor       Instructor?         @relation("MemberInstructor")
  gym              Gym                 @relation(fields: [gymId], references: [id], onDelete: Cascade)
  children         MemberRelation[]    @relation("AdultToChild")
  parents          MemberRelation[]    @relation("ChildToAdult")
  orders           Order[]
  subscriptions    Subscription[]
  user             User?               @relation("MemberUser")
  beltStripeLogs   MemberBeltStripeLog[]
  profileChangeLogs MemberProfileChangeLog[]
}

/// Links an adult member to a child member (e.g. parent → child).
model MemberRelation {
  id           String   @id @default(cuid())
  adultId      String
  childId      String
  relationship String
  createdAt    DateTime @default(now())
  adult        Member   @relation("AdultToChild", fields: [adultId], references: [id], onDelete: Cascade)
  child        Member   @relation("ChildToAdult", fields: [childId], references: [id], onDelete: Cascade)
}

/// Membership plan (e.g. Monthly Unlimited, 10-class pack).
model MembershipPlan {
  id                  String         @id @default(cuid())
  gymId               String
  locationId          String?
  name                String
  description         String?
  priceCents          Int
  durationDays        Int
  maxCheckInsPerMonth Int?
  /// Billing model for this plan (subscription vs pass).
  billingKind         PlanBillingKind @default(SUBSCRIPTION)
  /// Duration of the plan (1 month or 1 year).
  duration            PlanDuration    @default(ONE_MONTH)
  /// Age group: Adults or Kids & Juniors (subscriptions only).
  age                 PlanAge         @default(ADULTS)
  /// Number of visits for pass plans (1 or 10). Null for subscriptions.
  visits              PlanVisits?
  /// Stripe Product representing this plan.
  stripeProductId     String?
  /// Default Stripe Price for this plan.
  stripePriceId       String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  gym                 Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  location            Location?      @relation(fields: [locationId], references: [id])
  orderItems          OrderItem[]
  subscriptions       Subscription[]
}

/// A member's subscription to a membership plan.
model Subscription {
  id                   String             @id @default(cuid())
  memberId             String
  planId               String
  startsAt             DateTime
  endsAt               DateTime
  status               SubscriptionStatus @default(ACTIVE)
  autoRenew            Boolean            @default(false)
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  member               Member             @relation(fields: [memberId], references: [id], onDelete: Cascade)
  plan                 MembershipPlan     @relation(fields: [planId], references: [id], onDelete: Cascade)
}

/// Recurring class entry (e.g. Mon/Wed BJJ 18:00).
model Class {
  id           String             @id @default(cuid())
  gymId        String
  locationId   String?
  name         String
  discipline   String?
  dayOfWeek    Int
  startTime    String
  endTime      String
  capacity     Int?
  /// Age group for the class (17+, 4-6, 7-10, 11-15 years). Null = no restriction.
  age          ClassAge?
  instructorId String?
  /// Guest instructor names when instructorId is null (e.g. "Guests" selected).
  guestNames   String[]            @default([])
  /// Topic for guest-taught classes (e.g. seminar subject).
  topic        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  endAt        DateTime?
  mainCategory ClassMainCategory?
  /// Concrete instance timing for calendar and history.
  startAt      DateTime?
  subCategory  ClassSubCategory?
  /// When the instructor confirmed taking attendance.
  attendanceConfirmedAt DateTime?
  checkIns     CheckIn[]
  gym          Gym                @relation(fields: [gymId], references: [id], onDelete: Cascade)
  instructor   Instructor?        @relation(fields: [instructorId], references: [id])
  location     Location?          @relation(fields: [locationId], references: [id], onDelete: Cascade)
}

/// Instructor profile, optionally linked to a Member.
model Instructor {
  id          String  @id @default(cuid())
  gymId       String
  memberId    String? @unique
  name        String
  photoUrl    String?
  bio         String?
  disciplines String?
  classes     Class[]
  gym         Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member      Member? @relation("MemberInstructor", fields: [memberId], references: [id])
}

/// Check-in event for attendance tracking.
model CheckIn {
  id         String    @id @default(cuid())
  memberId   String
  locationId String?
  classId    String?
  checkedAt  DateTime  @default(now())
  /// Set when instructor marks member as attended.
  attended   Boolean   @default(false)
  class      Class?    @relation(fields: [classId], references: [id])
  location   Location? @relation(fields: [locationId], references: [id], onDelete: Cascade)
  member     Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

/// Special events such as seminars or competitions.
model Event {
  id            String              @id @default(cuid())
  gymId         String
  locationId    String
  name          String
  type          String
  startAt       DateTime
  endAt         DateTime
  priceCents    Int                 @default(0)
  capacity      Int?
  gym           Gym                 @relation(fields: [gymId], references: [id], onDelete: Cascade)
  location      Location            @relation(fields: [locationId], references: [id], onDelete: Cascade)
  registrations EventRegistration[]
  orderItems    OrderItem[]
}

/// A member's registration for an event.
model EventRegistration {
  id        String    @id @default(cuid())
  memberId  String
  eventId   String
  status    String    @default("registered")
  paidAt    DateTime?
  createdAt DateTime  @default(now())
  event     Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member    Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

/// A product sold in the webshop (merchandise, etc.).
model Product {
  id         String      @id @default(cuid())
  gymId      String
  locationId String?
  name       String
  sku        String?     @unique
  priceCents Int
  stock      Int         @default(0)
  imageUrl   String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  orderItems OrderItem[]
  gym        Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  location   Location?   @relation(fields: [locationId], references: [id])
}

/// An order in the webshop (for products, memberships, or events).
model Order {
  id                    String      @id @default(cuid())
  memberId              String?
  gymId                 String
  locationId            String?
  totalCents            Int
  status                String      @default("pending")
  stripePaymentIntentId String?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt
  gym                   Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  location              Location?   @relation(fields: [locationId], references: [id])
  member                Member?     @relation(fields: [memberId], references: [id])
  items                 OrderItem[]
}

/// An item within an Order.
model OrderItem {
  id         String          @id @default(cuid())
  orderId    String
  productId  String?
  planId     String?
  eventId    String?
  quantity   Int             @default(1)
  priceCents Int
  event      Event?          @relation(fields: [eventId], references: [id])
  order      Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  plan       MembershipPlan? @relation(fields: [planId], references: [id])
  product    Product?        @relation(fields: [productId], references: [id])
}

model MemberBeltStripeLog {
  id              String    @id @default(cuid())
  memberId        String
  changedByUserId String
  previousBelt    BeltRank?
  newBelt         BeltRank?
  previousStripes Int?
  newStripes      Int?
  changedAt       DateTime  @default(now())

  member        Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  changedByUser User   @relation("UserBeltStripeChanges", fields: [changedByUserId], references: [id])
}

model MemberProfileChangeLog {
  id              String   @id @default(cuid())
  memberId        String
  changedByUserId String
  fieldName       String
  previousValue   String?
  newValue        String?
  changedAt       DateTime @default(now())

  member        Member @relation(fields: [memberId], references: [id], onDelete: Cascade)
  changedByUser User   @relation("UserProfileChanges", fields: [changedByUserId], references: [id])
}

enum GymStatus {
  ACTIVE
  SUSPENDED
}

enum UserRole {
  PLATFORM_ADMIN
  GYM_ADMIN
  LOCATION_ADMIN
  STAFF
  INSTRUCTOR
  MEMBER
}

enum MemberStatus {
  ACTIVE
  INACTIVE
}

enum MemberType {
  ADULT
  CHILD
}

enum SubscriptionStatus {
  ACTIVE
  CHANGED
  EXPIRED
  CANCELLED
  PAUSED
}

enum PlanBillingKind {
  SUBSCRIPTION
  PASS
}

enum PlanDuration {
  ONE_MONTH
  ONE_YEAR
}

enum PlanAge {
  ADULTS
  KIDS_AND_JUNIORS
}

enum PlanVisits {
  ONE_VISIT
  TEN_VISITS
}

enum ClassAge {
  ALL_AGES
  ADULT_17_PLUS
  AGE_4_6
  AGE_7_10
  AGE_11_15
}

enum ClassMainCategory {
  OPEN_MAT
  GI
  NO_GI
  EVENT
  SEMINAR
  GRADUATION
}

enum ClassSubCategory {
  STAND_UP
  FUNDAMENTALS
  INTERMEDIATE
  ADVANCED
  COMPETITION
}

enum BeltRank {
  WHITE
  BLUE
  PURPLE
  BROWN
  BLACK
}
